[flake8]
# Flake8 configuration for code linting

max-line-length = 100
exclude = 
    .git,
    __pycache__,
    .pytest_cache,
    .venv,
    venv,
    ENV,
    env,
    build,
    dist,
    .terraform,
    *.egg-info

# Error codes to ignore
ignore =
    E203,
    E501,
    W503

# Complexity
max-complexity = 10

# Per-file ignores
per-file-ignores =
    __init__.py:F401
    tests/*:F401,F811,E402,F841,F541,E712,E226,C901
